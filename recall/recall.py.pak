# ── List item ─────────────────────────────────────────────────────────────────

def make_list_item(entry: dict) -> ListItem:
    cat   = entry["category"]
    badge = CAT_LABEL[cat]
    tags  = " ".join(f"#{t}" for t in entry["tags"][:3])
    li    = ListItem(
        Label(
            f"[li-{cat}]{badge}[/li-{cat}]  {esc(entry['title'])}"
            + (f"  [li-tags]{esc(tags)}[/li-tags]" if tags else ""),
            markup=True,
        )
    )
    li.id = f"e-{entry['id']}"  # type: ignore
    return li


# ── Main App ──────────────────────────────────────────────────────────────────

class RecallApp(App):
    CSS   = APP_CSS
    TITLE = "recall"

    def __init__(self):
        super().__init__()
        self.db          = DB()
        self._all:      list[dict] = []
        self._filtered: list[dict] = []
        self._selected   = 0
        self._mode       = Mode.NORMAL
        self._search_q   = ""
        self._cmd_buf    = ""
        self._cat_filter: Optional[str] = None
        self._kbuf       = ""       # for gg / dd / yy
        self._status_msg = ""
        self._stimer     = None

    # ── Layout ─────────────────────────────────────────────────────────────

    def compose(self) -> ComposeResult:
        yield Static("", id="header", markup=True)
        with Horizontal(id="tabs-row"):
            yield Static("ALL",  id="tab-all",  classes="tab on")
            yield Static("CMD",  id="tab-cmd",  classes="tab")
            yield Static("NOTE", id="tab-note", classes="tab")
            yield Static("TOOL", id="tab-tool", classes="tab")
        with Horizontal(id="body"):
            with Vertical(id="list-panel"):
                yield Static("", id="list-header")
                yield ListView(id="entry-list")
            with Vertical(id="preview-panel"):
                with ScrollableContainer(id="preview-scroll"):
                    yield Static("", id="preview-content", markup=True)
        yield Static("", id="cmdline", markup=True)

    def on_mount(self):
        self._reload()
        self._draw_header()
        self._draw_cmdline()

    # ── Key handling ───────────────────────────────────────────────────────

    def on_key(self, event: events.Key) -> None:
        event.stop()
        event.prevent_default()
        k = event.key
        c = event.character or ""
        {
            Mode.NORMAL:  self._normal,
            Mode.SEARCH:  self._search,
            Mode.COMMAND: self._command,
        }[self._mode](k, c)

    # ── NORMAL ─────────────────────────────────────────────────────────────

    def _normal(self, k: str, c: str):
        buf = self._kbuf

        # Multi-key combos
        if buf == "g" and k == "g":
            self._kbuf = ""; self._selected = 0; self._sync(); return
        if buf == "d" and k == "d":
            self._kbuf = ""; self._do_delete(); return
        if buf == "y" and k == "y":
            self._kbuf = ""; self._do_yank(); return
        if k in ("g", "d", "y"):
            self._kbuf = k; return
        self._kbuf = ""

        # Motion
        if   k in ("j", "down"):  self._move(1)
        elif k in ("k", "up"):    self._move(-1)
        elif k == "ctrl+d":       self._move(5)
        elif k == "ctrl+u":       self._move(-5)
        elif k == "G":            self._selected = max(0, len(self._filtered)-1); self._sync()

        # Actions
        elif k == "enter":        self._open_view()
        elif c == "a":            self._open_form(None)
        elif c == "e":            self._open_form(self._cur())
        elif c == "q":            self.exit()
        elif c == "?":            self.push_screen(HelpModal())

        # Filters
        elif c == "1":            self._set_cat(None)
        elif c == "2":            self._set_cat("command")
        elif c == "3":            self._set_cat("note")
        elif c == "4":            self._set_cat("tool")
        elif k == "tab":          self._cycle_cat()

        # Mode switches
        elif c == "/":
            self._mode = Mode.SEARCH; self._search_q = ""; self._refresh(); self._draw_cmdline()
        elif c == ":":
            self._mode = Mode.COMMAND; self._cmd_buf = ""; self._draw_cmdline()
        elif k == "escape":
            if self._search_q:
                self._search_q = ""; self._selected = 0; self._refresh()
            self._draw_cmdline()

    # ── SEARCH ─────────────────────────────────────────────────────────────

    def _search(self, k: str, c: str):
        if k == "escape":
            self._search_q = ""; self._mode = Mode.NORMAL
            self._selected = 0; self._refresh(); self._draw_cmdline()
        elif k == "enter":
            self._mode = Mode.NORMAL; self._draw_cmdline()
        elif k == "backspace":
            self._search_q = self._search_q[:-1]
            self._selected = 0; self._refresh(); self._draw_cmdline()
        elif c and len(c) == 1:
            self._search_q += c; self._selected = 0; self._refresh(); self._draw_cmdline()

    # ── COMMAND ────────────────────────────────────────────────────────────

    def _command(self, k: str, c: str):
        if k == "escape":
            self._mode = Mode.NORMAL; self._cmd_buf = ""; self._draw_cmdline()
        elif k == "enter":
            cmd = self._cmd_buf.strip()
            self._mode = Mode.NORMAL; self._cmd_buf = ""
            if cmd in ("q", "q!"):
                self.exit()
            else:
                self._flash(f"unknown: {cmd}")
            self._draw_cmdline()
        elif k == "backspace":
            self._cmd_buf = self._cmd_buf[:-1]; self._draw_cmdline()
        elif c and len(c) == 1:
            self._cmd_buf += c; self._draw_cmdline()

    # ── Actions ────────────────────────────────────────────────────────────

    def _do_delete(self):
        entry = self._cur()
        if not entry: return
        def _done(ok):
            if ok:
                self.db.delete(entry["id"]); self._reload()
                self._flash(f"deleted: {entry['title']}")
        self.push_screen(ConfirmModal(f"delete: {entry['title']!r} ?"), _done)

    def _do_yank(self):
        entry = self._cur()
        if entry:
            self._flash(yank_to_clipboard(entry["content"]))

    def _open_view(self):
        entry = self._cur()
        if not entry: return
        def _done(result):
            if isinstance(result, str) and result.startswith("status:"):
                self._flash(result[7:])
            elif result == "edit":
                self._open_form(entry)
        self.push_screen(ViewModal(entry), _done)

    def _open_form(self, entry: Optional[dict]):
        if entry is None and not isinstance(entry, dict):
            pass  # adding new
        def _done(result):
            if not result: return
            if self._cur() and entry:
                self.db.update(entry["id"], result["title"], result["content"],
                               result["category"], result["tags"])
                self._flash(f"updated: {result['title']}")
            else:
                self.db.add(result["title"], result["content"],
                            result["category"], result["tags"])
                self._flash(f"added: {result['title']}")
            self._reload()
        self.push_screen(FormModal(entry), _done)

    # ── Data ───────────────────────────────────────────────────────────────

    def _reload(self):
        self._all = self.db.all()
        self._refresh()

    def _refresh(self):
        self._filtered = fuzzy_filter(self._all, self._search_q, self._cat_filter)
        if self._selected >= len(self._filtered):
            self._selected = max(0, len(self._filtered) - 1)
        lv = self.query_one("#entry-list", ListView)
        lv.clear()
        for e in self._filtered:
            lv.append(make_list_item(e))
        n = len(self._filtered)
        self.query_one("#list-header", Static).update(
            f"  {n} entr{'y' if n == 1 else 'ies'}"
        )
        self._sync()

    def _move(self, d: int):
        if not self._filtered: return
        self._selected = max(0, min(len(self._filtered)-1, self._selected + d))
        self._sync()

    def _sync(self):
        lv = self.query_one("#entry-list", ListView)
        if self._filtered:
            lv.index = self._selected
        self._draw_preview()
        self._draw_header()

    def _cur(self) -> Optional[dict]:
        if 0 <= self._selected < len(self._filtered):
            return self._filtered[self._selected]
        return None

    # ── Drawing ────────────────────────────────────────────────────────────

    def _draw_preview(self):
        entry = self._cur()
        pane  = self.query_one("#preview-content", Static)
        if not entry:
            pane.update("[dim]  no entries — press [white]a[/white] to add one[/dim]")
            return
        pane.update(render_preview(entry))

    def _draw_header(self):
        total = len(self._filtered)
        pos   = (self._selected + 1) if total else 0
        mc    = {"NORMAL": "#1a3a4a", "SEARCH": "#00aacc", "COMMAND": "#aaaa00"}[self._mode.value]
        self.query_one("#header", Static).update(
            f"[bold #00d4aa]  ◈  RECALL[/bold #00d4aa]"
            f"  [dim]│[/dim]"
            f"  [bold {mc}]{self._mode.value}[/bold {mc}]"
            f"  [dim]{pos}/{total}[/dim]"
        )

    def _draw_cmdline(self):
        cl = self.query_one("#cmdline", Static)
        if self._mode == Mode.SEARCH:
            cl.update(f"[bold white]/[/bold white][cyan]{esc(self._search_q)}[/cyan][bold cyan]█[/bold cyan]")
        elif self._mode == Mode.COMMAND:
            cl.update(f"[bold white]:[/bold white][yellow]{esc(self._cmd_buf)}[/yellow][bold yellow]█[/bold yellow]")
        else:
            if self._status_msg:
                cl.update(f"  [#00d4aa]{esc(self._status_msg)}[/#00d4aa]")
            else:
                cl.update("  [dim]j/k ↕  /search  a add  e edit  dd del  yy yank  1-4 filter  Tab cycle  ? help  :q quit[/dim]")
        self._draw_header()

    def _flash(self, msg: str):
        self._status_msg = msg
        self._draw_cmdline()
        if self._stimer:
            self._stimer.cancel()
        self._stimer = self.set_timer(2.5, self._clear_flash)

    def _clear_flash(self):
        self._status_msg = ""
        self._stimer     = None
        self._draw_cmdline()

    # ── Filters ────────────────────────────────────────────────────────────

    def _set_cat(self, cat: Optional[str]):
        self._cat_filter = cat
        self._selected   = 0
        self._refresh()
        slugs = {None: "all", "command": "cmd", "note": "note", "tool": "tool"}
        for c2, slug in slugs.items():
            w = self.query_one(f"#tab-{slug}", Static)
            if c2 == cat: w.add_class("on")
            else:         w.remove_class("on")

    def _cycle_cat(self):
        cats = [None] + ALL_CATS
        idx  = cats.index(self._cat_filter) if self._cat_filter in cats else 0
        self._set_cat(cats[(idx + 1) % len(cats)])


# ── CLI ───────────────────────────────────────────────────────────────────────

def cli():
    args = sys.argv[1:]
    if not args:
        RecallApp().run()
        return
    cmd = args[0]
    if cmd == "add":
        import argparse
        p = argparse.ArgumentParser(prog="recall add")
        p.add_argument("-t", "--title",    required=True)
        p.add_argument("-c", "--content",  default="")
        p.add_argument("-C", "--category", default="note", choices=ALL_CATS)
        p.add_argument("--tags",           default="")
        ns = p.parse_args(args[1:])
        DB().add(ns.title, ns.content, ns.category,
                 [t.strip() for t in ns.tags.split(",") if t.strip()])
        print(f"added: {ns.title}")
    elif cmd == "search":
        if len(args) < 2: print("usage: recall search <query>"); sys.exit(1)
        for e in fuzzy_filter(DB().all(), " ".join(args[1:]), None):
            print(f"[{CAT_LABEL[e['category']]}] {e['title']}  |  {', '.join(e['tags'])}")
    elif cmd == "db-path":
        print(DB_PATH)
    else:
        print(f"unknown: {cmd}"); sys.exit(1)


if __name__ == "__main__":
    cli()
