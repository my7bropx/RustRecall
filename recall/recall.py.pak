class HelpModal(ModalScreen):
    DEFAULT_CSS = """
    HelpModal { align: center middle; }
    #help-box { background: #0d0d1a; border: solid #00d4aa; padding: 1 2; width: 58; height: auto; max-height: 92%; }
    """
    def compose(self) -> ComposeResult:
        with Container(id="help-box"):
            yield Static(HELP_TEXT, markup=True)

    def on_key(self, event: events.Key) -> None:
        event.stop()
        self.dismiss()


# ── Confirm Modal ─────────────────────────────────────────────────────────────

class ConfirmModal(ModalScreen):
    DEFAULT_CSS = """
    ConfirmModal { align: center middle; }
    #cb { background: #0d0d1a; border: solid red; padding: 1 3; width: 54; height: auto; }
    """
    def __init__(self, msg: str):
        super().__init__()
        self._msg = msg

    def compose(self) -> ComposeResult:
        with Container(id="cb"):
            yield Static(
                f"[bold red]{esc(self._msg)}[/bold red]\n\n"
                "  [dim]y[/dim]  confirm     [dim]n / Esc[/dim]  cancel",
                markup=True,
            )

    def on_key(self, event: events.Key) -> None:
        event.stop()
        self.dismiss(event.key in ("y", "Y"))


# ── View Modal ────────────────────────────────────────────────────────────────

class ViewModal(ModalScreen):
    DEFAULT_CSS = """
    ViewModal { align: center middle; }
    #vm-outer { background: #0d0d1a; border: solid #00d4aa; width: 92%; height: 90%; }
    #vm-bar   { height: 1; background: #070710; padding: 0 2; border-bottom: solid #1a1a2e; }
    #vm-scroll { height: 1fr; }
    #vm-content { height: auto; padding: 1 0; }
    #vm-hint  { height: 1; background: #030308; padding: 0 2; color: #2a2a4a; }
    """

    def __init__(self, entry: dict):
        super().__init__()
        self._entry   = entry
        self._pending = ""   # for gg / yy multi-key

    def compose(self) -> ComposeResult:
        cat = self._entry["category"]
        cc  = CAT_COLOR[cat]
        lbl = CAT_LABEL[cat]
        with Container(id="vm-outer"):
            yield Static(
                f"[{cc}]{lbl}[/{cc}]  [bold white]{esc(self._entry['title'])}[/bold white]",
                id="vm-bar", markup=True,
            )
            with ScrollableContainer(id="vm-scroll"):
                yield Static(render_preview(self._entry, 90), id="vm-content", markup=True)
            yield Static(
                "  j/k scroll   gg/G top/btm   Ctrl+d/u page   yy yank   e edit   q back",
                id="vm-hint",
            )

    def on_key(self, event: events.Key) -> None:
        event.stop()
        k  = event.key
        sc = self.query_one("#vm-scroll", ScrollableContainer)

        # multi-key
        if self._pending == "g" and k == "g":
            self._pending = ""
            sc.scroll_home(animate=False)
            return
        if self._pending == "y" and k == "y":
            self._pending = ""
            self.dismiss(f"status:{yank_to_clipboard(self._entry['content'])}")
            return
        if k in ("g", "y"):
            self._pending = k
            return
        self._pending = ""

        if k in ("q", "escape"):
            self.dismiss(None)
        elif k == "e":
            self.dismiss("edit")
        elif k in ("j", "down"):
            sc.scroll_down(animate=False)
        elif k in ("k", "up"):
            sc.scroll_up(animate=False)
        elif k == "ctrl+d":
            for _ in range(5): sc.scroll_down(animate=False)
        elif k == "ctrl+u":
            for _ in range(5): sc.scroll_up(animate=False)
        elif k == "G":
            sc.scroll_end(animate=False)


# ── Form Modal ────────────────────────────────────────────────────────────────

FIELD_NAMES  = ["title", "category", "tags", "content"]
FIELD_LABELS = ["Title   ", "Category", "Tags    ", "Content "]

class FormModal(ModalScreen):
    DEFAULT_CSS = """
    FormModal { align: center middle; }
    #fm-outer {
        background: #0d0d1a;
        border: solid #00d4aa;
        padding: 0 2 1 2;
        width: 84;
        height: auto;
        max-height: 92%;
    }
    #fm-header { color: #00d4aa; text-style: bold; height: 2; padding: 1 0 0 0; }
    .frow      { height: auto; margin-top: 1; }
    .fcur      { width: 2; color: #00d4aa; }
    .flbl      { width: 12; color: #2a2a4a; }
    .flbl.sel  { color: #00d4aa; }
    #cat-disp  { width: 1fr; }
    Input      { border: solid #1a1a2e; width: 1fr; }
    Input:focus{ border: solid #00d4aa; }
    TextArea   { border: solid #1a1a2e; height: 10; width: 1fr; }
    TextArea:focus { border: solid #00d4aa; }
    #fm-status { height: 1; margin-top: 1; }
    """

    def __init__(self, entry: Optional[dict] = None):
        super().__init__()
        self._entry   = entry
        self._nav_idx = 0
        self._editing = False
        self._cat_idx = ALL_CATS.index(entry["category"]) if entry else 0
        self._cmdbuf  = ""
        self._zbuf    = ""

    def compose(self) -> ComposeResult:
        e = self._entry or {}
        with Container(id="fm-outer"):
            yield Static(f" ◈  {'Edit' if self._entry else 'Add'} Entry", id="fm-header")
            with Horizontal(classes="frow"):
                yield Static(" ", classes="fcur", id="cur-title")
                yield Static(FIELD_LABELS[0], classes="flbl", id="lbl-title")
                yield Input(value=e.get("title", ""), id="f-title", placeholder="title...")
            with Horizontal(classes="frow"):
                yield Static(" ", classes="fcur", id="cur-category")
                yield Static(FIELD_LABELS[1], classes="flbl", id="lbl-category")
                yield Static("", id="cat-disp", markup=True)
            with Horizontal(classes="frow"):
                yield Static(" ", classes="fcur", id="cur-tags")
                yield Static(FIELD_LABELS[2], classes="flbl", id="lbl-tags")
                yield Input(value=", ".join(e.get("tags", [])), id="f-tags", placeholder="tag1, tag2...")
            with Horizontal(classes="frow"):
                yield Static(" ", classes="fcur", id="cur-content")
                yield Static(FIELD_LABELS[3], classes="flbl", id="lbl-content")
                yield TextArea(e.get("content", ""), id="f-content")
            yield Static("", id="fm-status", markup=True)

    def on_mount(self):
        self._refresh_cat()
        self._refresh_sel()
        self._refresh_status()

    # ── Keys ───────────────────────────────────────────────────────────────

    def on_key(self, event: events.Key) -> None:
        k = event.key
        c = event.character or ""

        # INSERT mode — only intercept Esc and Ctrl+O
        if self._editing:
            if k == "escape":
                event.stop(); event.prevent_default()
                self._editing = False
                self.set_focus(None)
                self._refresh_status()
            elif k == "ctrl+o":
                event.stop(); event.prevent_default()
                self._run_editor()
            return

        # NAV mode — consume everything
        event.stop()
        event.prevent_default()

        # Command buffer (:w / :q)
        if self._cmdbuf:
            if k == "escape":
                self._cmdbuf = ""
                self._refresh_status()
                return
            self._cmdbuf += c or k
            if self._cmdbuf == ":w":
                self._cmdbuf = ""
                self._save()
            elif self._cmdbuf == ":q":
                self._cmdbuf = ""
                self.dismiss(None)
            elif len(self._cmdbuf) > 3:
                self._cmdbuf = ""
                self._refresh_status()
            else:
                self._refresh_status(self._cmdbuf)
            return

        # ZZ
        if self._zbuf == "Z" and k == "Z":
            self._zbuf = ""
            self._save()
            return
        if k == "Z":
            self._zbuf = "Z"
            return
        self._zbuf = ""

        # Navigation
        if k in ("j", "down", "tab"):
            self._nav_idx = (self._nav_idx + 1) % 4
            self._refresh_sel()
        elif k in ("k", "up", "shift+tab"):
            self._nav_idx = (self._nav_idx - 1) % 4
            self._refresh_sel()

        # Enter insert mode or interact
        elif k in ("i", "a", "enter"):
            if self._nav_idx == 1:
                self._cycle_cat(1)
            else:
                self._start_insert()

        # Category cycling
        elif k in ("left",) and self._nav_idx == 1:
            self._cycle_cat(-1)
        elif k in ("right",) and self._nav_idx == 1:
            self._cycle_cat(1)

        # Ctrl+O — open editor on content field
        elif k == "ctrl+o":
            self._nav_idx = 3
            self._refresh_sel()
            self._run_editor()

        # Command prefix
        elif c == ":":
            self._cmdbuf = ":"
            self._refresh_status(":")

        # Cancel
        elif k in ("q", "escape"):
            self.dismiss(None)

    # ── Insert helpers ─────────────────────────────────────────────────────

    def _start_insert(self):
        wids = ["#f-title", None, "#f-tags", "#f-content"]
        wid  = wids[self._nav_idx]
        if wid:
            self._editing = True
            self.query_one(wid).focus()
            self._refresh_status()

    # ── Category ───────────────────────────────────────────────────────────

    def _cycle_cat(self, d: int):
        self._cat_idx = (self._cat_idx + d) % len(ALL_CATS)
        self._refresh_cat()

    def _refresh_cat(self):
        cat = ALL_CATS[self._cat_idx]
        cc  = CAT_COLOR[cat]
        lbl = CAT_LABEL[cat]
        self.query_one("#cat-disp", Static).update(
            f"  [dim]◀[/dim]  [{cc}]{lbl}[/{cc}]  [dim]▶[/dim]  [dim]← →  or  Enter  to cycle[/dim]"
        )

    # ── Selection indicator ────────────────────────────────────────────────

    def _refresh_sel(self):
        for i, name in enumerate(FIELD_NAMES):
            active = (i == self._nav_idx)
            self.query_one(f"#cur-{name}", Static).update("▶" if active else " ")
            lbl = self.query_one(f"#lbl-{name}", Static)
            if active:
                lbl.add_class("sel")
            else:
                lbl.remove_class("sel")
        self._refresh_status()

    # ── Status bar ─────────────────────────────────────────────────────────

    def _refresh_status(self, cmd_hint: str = ""):
        if cmd_hint:
            self.query_one("#fm-status", Static).update(
                f"[bold yellow]{esc(cmd_hint)}[/bold yellow][dim]_[/dim]"
            )
            return
        if self._editing:
            self.query_one("#fm-status", Static).update(
                "[bold cyan]-- INSERT --[/bold cyan]  [dim]Esc exit   Ctrl+O editor[/dim]"
            )
        else:
            self.query_one("#fm-status", Static).update(
                "[dim]-- NAV --  j/k move   i edit   ← → cat   ZZ save   :q cancel   Ctrl+O editor[/dim]"
            )

    # ── Save ──────────────────────────────────────────────────────────────

    def _save(self):
        title   = self.query_one("#f-title",   Input).value.strip()
        tags_s  = self.query_one("#f-tags",    Input).value
        content = self.query_one("#f-content", TextArea).text
        if not title:
            self._refresh_status()
            self.query_one("#fm-status", Static).update("[bold red]title cannot be empty[/bold red]")
            return
        self.dismiss({
            "title":    title,
            "category": ALL_CATS[self._cat_idx],
            "tags":     [t.strip() for t in tags_s.split(",") if t.strip()],
            "content":  content,
        })

    # ── $EDITOR ───────────────────────────────────────────────────────────

    def _run_editor(self):
        editor  = os.environ.get("EDITOR", "nano")
        content = self.query_one("#f-content", TextArea).text
        with tempfile.NamedTemporaryFile(suffix=".txt", mode="w", delete=False) as f:
            f.write(content)
            tmp = f.name
        self.app.suspend()
        subprocess.run([editor, tmp])
        self.app.resume()
        try:
            self.query_one("#f-content", TextArea).load_text(Path(tmp).read_text())
        except Exception:
            pass
        finally:
            Path(tmp).unlink(missing_ok=True)
        self._nav_idx = 3
        self._refresh_sel()


