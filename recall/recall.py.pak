#!/usr/bin/env python3
"""recall — vim-native terminal knowledge base"""

import os
import re
import sqlite3
import subprocess
import sys
import tempfile
from datetime import datetime
from enum import Enum
from pathlib import Path
from typing import Optional

from rapidfuzz import fuzz
from rich.markup import escape as esc
from textual import events
from textual.app import App, ComposeResult
from textual.containers import Container, Horizontal, ScrollableContainer, Vertical
from textual.screen import ModalScreen
from textual.widgets import Input, Label, ListItem, ListView, Static, TextArea

# ── Constants ─────────────────────────────────────────────────────────────────

DB_PATH   = Path.home() / ".local" / "share" / "recall" / "recall.db"
ALL_CATS  = ["command", "note", "tool"]
CAT_LABEL = {"command": "CMD ", "note": "NOTE", "tool": "TOOL"}
CAT_COLOR = {"command": "green", "note": "yellow", "tool": "cyan"}

class Mode(Enum):
    NORMAL  = "NORMAL"
    SEARCH  = "SEARCH"
    COMMAND = "COMMAND"

# ── Database ──────────────────────────────────────────────────────────────────

class DB:
    def __init__(self, path: Path = DB_PATH):
        path.parent.mkdir(parents=True, exist_ok=True)
        self.conn = sqlite3.connect(str(path))
        self.conn.row_factory = sqlite3.Row
        self._init()

    def _init(self):
        self.conn.executescript("""
            CREATE TABLE IF NOT EXISTS entries (
                id          INTEGER PRIMARY KEY AUTOINCREMENT,
                title       TEXT NOT NULL,
                content     TEXT NOT NULL DEFAULT '',
                category    TEXT NOT NULL DEFAULT 'note',
                tags        TEXT NOT NULL DEFAULT '',
                created_at  TEXT NOT NULL,
                updated_at  TEXT NOT NULL
            );
        """)
        self.conn.commit()

    def _row(self, row) -> dict:
        r = dict(row)
        r["tags"] = [t.strip() for t in r["tags"].split(",") if t.strip()] if r["tags"] else []
        return r

    def all(self) -> list[dict]:
        return [self._row(r) for r in self.conn.execute(
            "SELECT * FROM entries ORDER BY updated_at DESC"
        ).fetchall()]

    def add(self, title, content, category, tags) -> int:
        now = _now()
        cur = self.conn.execute(
            "INSERT INTO entries (title,content,category,tags,created_at,updated_at) VALUES (?,?,?,?,?,?)",
            (title, content, category, ",".join(t.strip() for t in tags if t.strip()), now, now),
        )
        self.conn.commit()
        return cur.lastrowid  # type: ignore

    def update(self, id, title, content, category, tags):
        self.conn.execute(
            "UPDATE entries SET title=?,content=?,category=?,tags=?,updated_at=? WHERE id=?",
            (title, content, category, ",".join(t.strip() for t in tags if t.strip()), _now(), id),
        )
        self.conn.commit()

    def delete(self, id):
        self.conn.execute("DELETE FROM entries WHERE id=?", (id,))
        self.conn.commit()


def _now() -> str:
    return datetime.now().strftime("%Y-%m-%d %H:%M")


# ── Fuzzy filter ──────────────────────────────────────────────────────────────

def fuzzy_filter(entries: list[dict], query: str, cat: Optional[str]) -> list[dict]:
    if cat:
        entries = [e for e in entries if e["category"] == cat]
    q = query.strip().lower()
    if not q:
        return entries
    def score(e):
        hay = f"{e['title']} {' '.join(e['tags'])} {e['content'][:400]}".lower()
        return fuzz.partial_ratio(q, hay)
    scored = [(e, score(e)) for e in entries]
    scored = [(e, s) for e, s in scored if s > 55]
    scored.sort(key=lambda x: x[1], reverse=True)
    return [e for e, _ in scored]


# ── Preview renderer ──────────────────────────────────────────────────────────

def render_preview(entry: dict, width: int = 60) -> str:
    cat   = entry["category"]
    cc    = CAT_COLOR[cat]
    label = CAT_LABEL[cat]
    tags  = ", ".join(entry["tags"]) or "(none)"
    sep   = "─" * min(width - 4, 54)

    lines = [
        f"  [dim]Title    [/dim][bold {cc}]{esc(entry['title'])}[/bold {cc}]",
        f"  [dim]Category [/dim][{cc}]{label}[/{cc}]",
        f"  [dim]Tags     [/dim][cyan]{esc(tags)}[/cyan]",
        f"  [dim]Updated  [/dim][dim]{esc(entry['updated_at'])}[/dim]",
        f"  [dim]{sep}[/dim]",
        "",
    ]

    in_code = False
    for line in entry["content"].splitlines():
        stripped = line.strip()
        if stripped.startswith("```"):
            in_code = not in_code
            lang    = stripped[3:].strip()
            bar     = f"  {lang} " if lang else "  "
            lines.append(f"  [dim]{'━'*min(width-4,54)}[/dim]  [dim]{esc(lang)}[/dim]" if lang
                          else f"  [dim]{'━'*min(width-4,54)}[/dim]")
            continue
        if in_code:
            lines.append(f"  [bold green]  {esc(line)}[/bold green]")
        else:
            lines.append(f"  {esc(line)}")

    return "\n".join(lines)


# ── Clipboard yank ────────────────────────────────────────────────────────────

def yank_to_clipboard(text: str) -> str:
    for cmd in [
        ["xclip", "-selection", "clipboard"],
        ["xsel",  "--clipboard", "--input"],
        ["wl-copy"],
    ]:
        try:
            p = subprocess.run(cmd, input=text.encode(), capture_output=True)
            if p.returncode == 0:
                return f"yanked via {cmd[0]}"
        except FileNotFoundError:
            continue
    return "install xclip / xsel / wl-copy for clipboard"


