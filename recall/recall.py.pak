  [bold white]COMMAND[/bold white]  [dim](after :)[/dim]
  [cyan]:q[/cyan]             quit
  [cyan]Esc[/cyan]            cancel

  [bold white]VIEW[/bold white]
  [cyan]j / k[/cyan]          scroll
  [cyan]gg / G[/cyan]         top / bottom
  [cyan]Ctrl+d / Ctrl+u[/cyan]  page scroll
  [cyan]yy[/cyan]             yank content
  [cyan]e[/cyan]              edit entry
  [cyan]q / Esc[/cyan]        back to list

  [bold white]FORM — NAV mode[/bold white]
  [cyan]j / k[/cyan]          move between fields
  [cyan]i / Enter[/cyan]      edit selected field  [dim]→ INSERT[/dim]
  [cyan]← / →[/cyan]          cycle category
